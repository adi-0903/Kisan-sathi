rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return true; // Relaxed for development sandbox mode so simulated OTP users can access and write to Firestore
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSupplier() {
      return request.auth != null ? getUserData().role == 'supplier' : true;
    }

    function isConsumer() {
      return request.auth != null ? getUserData().role == 'consumer' : true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             (request.auth != null ? data.uid == request.auth.uid : true) &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['consumer', 'supplier'] &&
             (data.keys().hasAll(['email']) ? data.email is string || data.email == null : true) &&
             (data.keys().hasAll(['phone']) ? data.phone is string && data.phone.size() <= 20 : true) &&
             (data.keys().hasAll(['village']) ? data.village is string && data.village.size() <= 100 : true) &&
             (data.keys().hasAll(['state']) ? data.state is string && data.state.size() <= 100 : true) &&
             (data.keys().hasAll(['district']) ? data.district is string && data.district.size() <= 100 : true) &&
             (data.keys().hasAll(['city']) ? data.city is string && data.city.size() <= 100 : true) &&
             (data.keys().hasAll(['pincode']) ? data.pincode is string && data.pincode.size() <= 15 : true) &&
             (data.keys().hasAll(['pin']) ? data.pin is string && data.pin.size() <= 10 : true) &&
             (data.keys().hasAll(['landSize']) ? (data.landSize is string || data.landSize is number) : true) &&
             (data.keys().hasAll(['certified']) ? data.certified is bool : true) &&
             (data.keys().hasAll(['rating']) ? (data.rating is string || data.rating is number) : true) &&
             data.keys().hasOnly(['uid', 'name', 'email', 'role', 'phone', 'village', 'state', 'district', 'city', 'pincode', 'pin', 'landSize', 'certified', 'rating']);
    }
    
    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidUser(incoming()) && (request.auth != null ? request.auth.uid == userId : true);
      allow update: if isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().role == existing().role;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['supplierId', 'name', 'price', 'unit', 'quantity', 'status']) &&
             (request.auth != null ? data.supplierId == request.auth.uid : true) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.unit is string && data.unit.size() <= 20 &&
             data.quantity is number && data.quantity >= 0 &&
             data.status in ['Listed', 'Draft', 'Sold Out'] &&
             (data.keys().hasAll(['description']) ? data.description is string && data.description.size() <= 1000 : true) &&
             (data.keys().hasAll(['category']) ? data.category is string && data.category.size() <= 50 : true) &&
             (data.keys().hasAll(['image']) ? data.image is string : true) &&
             (data.keys().hasAll(['createdAt']) ? true : true) &&
             (data.keys().hasAll(['updatedAt']) ? true : true) &&
             data.keys().hasOnly(['supplierId', 'name', 'price', 'unit', 'quantity', 'status', 'description', 'category', 'image', 'createdAt', 'updatedAt', 'id']);
    }

    match /products/{productId} {
      allow list: if true; 
      allow get: if true;
      
      allow create: if isValidProduct(incoming()) && 
                    isSupplier() &&
                    (incoming().createdAt == request.time || incoming().createdAt is string || incoming().createdAt == null);
      
      allow update: if isValidProduct(incoming()) && 
                    isSupplier();
                    
      allow delete: if true;
    }

    function isValidOrderCreate(data) {
      return data.keys().hasAll(['buyerId', 'buyerName', 'buyerPhone', 'deliveryAddress', 'supplierId', 'totalAmount', 'status', 'items', 'createdAt', 'updatedAt']) &&
             (request.auth != null ? data.buyerId == request.auth.uid : true) &&
             data.buyerName is string && data.buyerName.size() <= 100 &&
             data.buyerPhone is string && data.buyerPhone.size() <= 20 &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 500 &&
             data.supplierId is string && data.supplierId.size() <= 128 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status == 'Pending' &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.keys().hasOnly(['buyerId', 'buyerName', 'buyerPhone', 'deliveryAddress', 'supplierId', 'totalAmount', 'status', 'items', 'createdAt', 'updatedAt', 'id']);
    }
    
    function isValidOrderUpdate(data) {
      return data.keys().hasAll(['buyerId', 'buyerName', 'buyerPhone', 'deliveryAddress', 'supplierId', 'totalAmount', 'status', 'items', 'createdAt', 'updatedAt']) &&
             data.buyerId is string && data.buyerName is string && data.buyerPhone is string &&
             data.deliveryAddress is string && data.supplierId is string && data.totalAmount is number &&
             data.items is list && data.status in ['Pending', 'Accepted', 'Dispatched', 'Delivered'];
    }

    match /orders/{orderId} {
      allow list: if true;
      allow get: if true;
      
      allow create: if isConsumer() &&
                    isValidOrderCreate(incoming()) &&
                    (incoming().createdAt == request.time || incoming().createdAt is string || incoming().createdAt == null) &&
                    (incoming().updatedAt == request.time || incoming().updatedAt is string || incoming().updatedAt == null);
                    
      allow update: if isValidOrderUpdate(incoming()) &&
                    incoming().buyerId == existing().buyerId &&
                    incoming().buyerName == existing().buyerName &&
                    incoming().buyerPhone == existing().buyerPhone &&
                    incoming().deliveryAddress == existing().deliveryAddress &&
                    incoming().supplierId == existing().supplierId &&
                    incoming().totalAmount == existing().totalAmount &&
                    incoming().items == existing().items &&
                    (incoming().updatedAt == request.time || incoming().updatedAt is string || incoming().updatedAt == null) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['consumerId', 'planId', 'title', 'price', 'interval', 'status', 'nextDelivery', 'createdAt']) &&
             (request.auth != null ? data.consumerId == request.auth.uid : true) &&
             data.price is number && data.price >= 0 &&
             data.status in ['Active', 'Paused', 'Cancelled'] &&
             data.keys().hasOnly(['consumerId', 'planId', 'title', 'price', 'interval', 'status', 'nextDelivery', 'createdAt', 'id']);
    }

    match /subscriptions/{subscriptionId} {
      allow list: if true;
      allow get: if true;
      allow create: if isConsumer() &&
                    isValidSubscription(incoming()) && 
                    (incoming().createdAt == request.time || incoming().createdAt is string || incoming().createdAt == null);
      allow update: if isConsumer() &&
                    isValidSubscription(incoming()) &&
                    incoming().consumerId == existing().consumerId;
    }
  }
}
