{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing role and optional details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["consumer", "supplier"] },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "village": { "type": "string" },
        "state": { "type": "string" }
      },
      "required": ["uid", "name", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product listing directly from a supplier.",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["Listed", "Draft", "Sold Out"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "name", "price", "unit", "quantity", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a consumer for a specific supplier.",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "buyerPhone": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "supplierId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Accepted", "Dispatched", "Delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "buyerName", "buyerPhone", "deliveryAddress", "supplierId", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Supplier product listings"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Consumer orders"
    }
  }
}
