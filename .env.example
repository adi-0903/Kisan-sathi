# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Groq AI API key.
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENWEATHER_API_KEY: Optional. Fetches real weather forecasts and precipitation data.
# Sign up at https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY="YOUR_OPENWEATHERMAP_API_KEY"

# DATAGOVIN_API_KEY: Optional. Fetches live mandi market prices via agmarknet data.
# Sign up at https://data.gov.in
DATAGOVIN_API_KEY="YOUR_DATAGOVIN_API_KEY"

# NEON_DATABASE_URL: Used for Postgres backend integration.
NEON_DATABASE_URL="postgresql://neondb_owner:..."

# Twilio Integration (Optional, falls back to free sandbox OTP if not provided)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

